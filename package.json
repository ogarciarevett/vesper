{
	"name": "openclaw-village",
	"private": true,
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"scripts": {
		"build": "rimraf .turbo && turbo run build --force",
		"prepare": "husky",
		"commit": "turbo run lint test --filter=...[HEAD] --concurrency=1 && SKIP_PRECOMMIT=1 cz",
		"database:generate": "turbo run database:generate",
		"database:push": "turbo run database:push",
		"deploy": "turbo run deploy",
		"dev": "turbo run dev --parallel",
		"start": "turbo run start --filter",
		"test": "turbo run test --filter",
		"lint": "turbo run lint --filter",
		"lint:fix": "turbo run lint:fix --filter",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"prettier": "^3.6.2",
		"rimraf": "^6.1.2",
		"turbo": "^2.8.8",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.2.20",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
