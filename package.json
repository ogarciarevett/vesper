{
  "name": "vesper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first runtime for personal automation agents.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "help": "echo 'Vesper quick start:  bun run init  ->  bun run start (boots daemon + opens Vesper World UI).  CLI: bun run vesper <command> (e.g. bun run vesper status).  Daemon: bun run daemon (foreground) or daemon:start | daemon:stop | daemon:status.  UI only: bun run ui (needs the daemon running).'",
    "init": "bun packages/vesper-cli/src/index.ts init",
    "start": "bun packages/vesper-cli/src/index.ts daemon start && bun packages/vesper-cli/src/index.ts ui",
    "vesper": "bun packages/vesper-cli/src/index.ts",
    "cli": "bun packages/vesper-cli/src/index.ts",
    "ui": "bun packages/vesper-cli/src/index.ts ui",
    "daemon": "bun packages/vesper-cli/src/index.ts daemon run",
    "daemon:start": "bun packages/vesper-cli/src/index.ts daemon start",
    "daemon:stop": "bun packages/vesper-cli/src/index.ts daemon stop",
    "daemon:status": "bun packages/vesper-cli/src/index.ts daemon status",
    "status": "bun packages/vesper-cli/src/index.ts status",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "sync:ai": "bun scripts/sync-ai-docs.ts",
    "docs:cli": "bun scripts/gen-cli-docs.ts",
    "build:daemon": "bun scripts/build-daemon.ts",
    "build:dist": "bun scripts/build-dist.ts",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@vesper/ui": "workspace:*"
  }
}
