# Cloudflare AI Gateway
CF_AI_GATEWAY_ACCOUNT_ID="your-cf-account-id"
CF_AI_GATEWAY_ID="openclaw-core"
# CF_AIG_AUTH_TOKEN="your-cf-aig-token"
# CF_AI_DEFAULT_MODEL="anthropic/claude-opus-4-6"
# Optional catalog for dashboard model dropdown + backend BYOK checks.
# CF_AI_MODEL_CATALOG='[{"id":"opus46","label":"Anthropic Opus 4.6","model":"anthropic/claude-opus-4-6","byokAlias":"anthropic-default"},{"id":"gemini3pro","label":"Gemini 3 Pro","model":"google-ai-studio/gemini-3-pro","byokAlias":"google-default"}]'
# Optional cache TTL for model health probes (ms).
# CF_AI_MODEL_CHECK_TTL_MS="30000"

# Hyperliquid (Trading)
HL_PRIVATE_KEY="your-private-key-hex"
HL_WALLET_ADDRESS="your-wallet-address"
# HYPERLIQUID_TESTNET="true"

# OpenClaw Security (required)
OPENCLAW_GATEWAY_PASSWORD="your-local-gateway-password"

# Optional CCXT fallback
# ENABLE_CCXT_FALLBACK="true"
# CCXT_BINANCE_API_KEY="your-binance-api-key"
# CCXT_BINANCE_API_SECRET="your-binance-api-secret"
# CCXT_BINANCE_TESTNET="true"
