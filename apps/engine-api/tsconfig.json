{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@repo/hyperliquid-sdk": ["../../packages/hyperliquid-sdk/src/index.ts"],
      "@repo/hyperliquid-sdk/*": ["../../packages/hyperliquid-sdk/src/*"]
    }
  },
  "include": ["src/**/*", "worker-configuration.d.ts"]
}