#!/bin/sh
# Guard: generated agent docs must stay in sync with the single sources of truth
# (.ai/context.md + .ai/pipeline.md). Regenerate, then fail the commit if any generated
# file changed — i.e. it was stale, or someone hand-edited a generated file.
#
# To fix a failure: edit .ai/context.md / .ai/pipeline.md (never the generated files),
# run `bun run sync:ai`, then `git add` the regenerated files and commit again.
set -e

bun run sync:ai >/dev/null

GENERATED="AGENTS.md CLAUDE.md GEMINI.md .ai/generated/rules.mdc"
if ! git diff --quiet -- $GENERATED; then
  echo "ERROR: generated agent docs are stale — run 'bun run sync:ai' and re-stage:"
  git --no-pager diff --name-only -- $GENERATED | sed 's/^/    /'
  exit 1
fi

# Guard: docs/CLI.md must list every `vesper` command. Regenerate it from the
# command registry, then fail if it changed — i.e. a command was added/edited
# without refreshing the reference (or docs/CLI.md was hand-edited).
#
# To fix a failure: run `bun run docs:cli`, then `git add docs/CLI.md` and commit again.
bun run docs:cli >/dev/null

if ! git diff --quiet -- docs/CLI.md; then
  echo "ERROR: docs/CLI.md is stale — run 'bun run docs:cli' and re-stage docs/CLI.md"
  exit 1
fi
